  <!-- Using the Beckmans stylesheets to render the spreadsheet grid -->
  <link href="style.css" rel="stylesheet">
  <style>
    /* --- RESET E VARIABILI --- */
    :root {
        --border: 0.5px solid #000;
        --cell-height: 40px; /* Altezza di base delle righe */
        --hover-height: 250px; /* Altezza quando si apre l'immagine */
    }
    
    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background: #f4f4f4; /* Grigio chiarissimo tipico dei fogli di calcolo */
        color: #000;
    }
    
    a { text-decoration: none; color: inherit; }
    h1, h2, h3 { font-family: 'Fraunces', serif; font-weight: 300; margin: 0; }

    /* --- STRUTTURA DELLA GRIGLIA (SPREADSHEET) --- */
    .table.grid {
        display: grid;
        /* Definisce le larghezze delle colonne: faux, index, name, e poi 14 cellette uguali */
        grid-template-columns: 20px 40px 300px repeat(14, 1fr);
        border-top: var(--border);
        border-left: var(--border);
        width: 100%;
    }

    /* Le singole celle della riga */
    .table__cell__index, 
    .table__cell__name, 
    .table__cell__standard,
    .table__cell__faux {
        border-right: var(--border);
        border-bottom: var(--border);
        height: var(--cell-height);
        display: flex;
        align-items: center;
        overflow: hidden;
        transition: height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        background: #fff;
    }

    /* Spaziature interne */
    .cell--space--left { padding-left: 1rem; }
    .cell--align--center { justify-content: center; width: 100%; }

    /* --- RIGHE CATEGORIE (Narrative / Analytical) --- */
    .empty--row .table__cell__index { padding: 0; }
    .class__color { width: 100%; height: 100%; } /* Il quadratino colorato */

    /* --- L'EFFETTO IMMAGINE (IL TRUCCO BECKMANS) --- */
    /* La cella dell'immagine all'inizio è stretta e bassa */
    .image--cell {
        grid-column: span 1; /* Occupa 1 colonna */
        position: relative;
        padding: 0 !important;
        transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* L'immagine schiacciata al centro (spreadsheet mode) */
    .image--cell img {
        width: 100%;
        height: 100%;
        object-fit: none; /* LA MAGIA: taglia e sgrana l'immagine per farla entrare */
        object-position: center;
        transition: object-fit 0.4s ease;
    }

    /* --- HOVER: L'INTERAZIONE --- */
    /* Quando passi col mouse su un'intera riga articolo... */
    .content__table:hover .table__cell__index,
    .content__table:hover .table__cell__name,
    .content__table:hover .table__cell__standard,
    .content__table:hover .table__cell__faux {
        height: var(--hover-height); /* Tutte le celle della riga diventano alte */
        background: #f9f9f9; /* Leggero feedback visivo */
    }

    /* ...la cella dell'immagine si allarga a dismisura... */
    .content__table:hover .image--cell {
        grid-column: span 4; /* Si mangia 4 colonne invece di 1 */
        z-index: 10;
    }

    /* ...e l'immagine si ricompone diventando bellissima */
    .content__table:hover .image--cell img {
        object-fit: cover; /* Torna proporzionata e copre l'area */
    }

    /* Colori al passaggio per simulare i link Beckmans */
    .content__table:hover .table__cell__name h3,
    .content__table:hover .table__cell__index .table__cell__inner {
        color: blue;
    }
</style>
</head>
